# =================================================================
# Configuracao do Verificador / Emissor DPP - Workshop Cardano
# =================================================================
# Copie este arquivo para `.env` e preencha com suas credenciais.
# NUNCA faca commit do arquivo .env (ja esta no .gitignore).

# -----------------------------------------------------------------
# Blockfrost - PREPROD
# -----------------------------------------------------------------
# 1. Crie conta gratuita em https://blockfrost.io
# 2. Novo projeto -> Network: "Cardano preprod"
# 3. Copie o Project ID (comeca com "preprod...")
BLOCKFROST_PROJECT_ID=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------
# UVerify
# -----------------------------------------------------------------
# A API publica do UVerify NAO exige API key. O SDK Python usa por
# padrao https://api.preprod.uverify.io. Ajuste so se for self-hosted.
UVERIFY_API_URL=https://api.preprod.uverify.io

# -----------------------------------------------------------------
# Verificador (Secao 3) - hash da credencial do pack a verificar
# -----------------------------------------------------------------
TX_HASH_PACK=
DATA_HASH_PACK=

# -----------------------------------------------------------------
# Emissor via Python (Secao 7) - SOMENTE PARA TESTNET / PREPROD
# -----------------------------------------------------------------
# Mnemonico de 24 palavras da carteira preprod (mesma criada no
# Eternl/Lace). Usado para derivar a chave de assinatura via CIP-1852.
#
# >>> NUNCA cole aqui um mnemonico de carteira mainnet. <<<
WALLET_MNEMONIC=

# Hashes das credenciais ja emitidas (preencha conforme cada ator
# emite a sua). Sao referenciados pelos atores subsequentes na cadeia
# (cert_origem_credential_tx, cert_celula_credential_tx, etc.).
ATOR1_TX=
ATOR2_TX=
ATOR3_TX=
